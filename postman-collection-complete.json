	"event": [
		{
			"listen": "prerequest",
			"script": {
				"type": "text/javascript",
				"exec": [
					"// Set base URL based on environment",
					"if (pm.environment.get('environment') === 'production') {",
					"    pm.collectionVariables.set('baseUrl', pm.collectionVariables.get('prodUrl'));",
					"} else {",
					"    pm.collectionVariables.set('baseUrl', 'http://localhost:3000/api');",
					"}"
				]
			}
		},
		{
			"listen": "test",
			"script": {
				"type": "text/javascript",
				"exec": [
					"// Auto-extract tokens and IDs from responses",
					"if (pm.response.json() && pm.response.json().data) {",
					"    const data = pm.response.json().data;",
					"    ",
					"    // Set Firebase token",
					"    if (data.token) {",
					"        pm.collectionVariables.set('firebaseToken', data.token);",
					"        if (data.user && data.user.role === 'admin') {",
					"            pm.collectionVariables.set('adminToken', data.token);",
					"        }",
					"    }",
					"    ",
					"    // Set IDs",
					"    if (data.uid) pm.collectionVariables.set('userId', data.uid);",
					"    if (data._id && pm.request.url.toString().includes('health-units')) {",
					"        pm.collectionVariables.set('healthUnitId', data._id);",
					"    }",
					"    if (data._id && pm.request.url.toString().includes('appointments')) {",
					"        pm.collectionVariables.set('appointmentId', data._id);",
					"    }",
					"}",
					"",
					"// Basic tests",
					"pm.test('Status code is successful', function () {",
					"    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
					"});",
					"",
					"pm.test('Response time is acceptable', function () {",
					"    pm.expect(pm.response.responseTime).to.be.below(5000);",
					"});"
				]
			}
		}
	]
}