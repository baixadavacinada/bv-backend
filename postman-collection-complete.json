  "item": [
    {
      "name": "🔥 Authentication Flow (Firebase Simulation)",
      "description": "Simula exatamente o fluxo de autenticação que o frontend React/Next.js faz",
      "item": [
        {
          "name": "1. Register New User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Test response",
                  "pm.test('User registration successful', function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});",
                  "",
                  "// Extract and save user data",
                  "if (pm.response.code === 200 || pm.response.code === 201) {",
                  "    const jsonData = pm.response.json();",
                  "    ",
                  "    if (jsonData.success && jsonData.data) {",
                  "        if (jsonData.data.token) {",
                  "            pm.collectionVariables.set('firebaseToken', jsonData.data.token);",
                  "            console.log('✅ Firebase token saved:', jsonData.data.token.substring(0, 50) + '...');",
                  "        }",
                  "        ",
                  "        if (jsonData.data.user) {",
                  "            pm.collectionVariables.set('userId', jsonData.data.user.uid || jsonData.data.user._id);",
                  "            console.log('✅ User ID saved:', jsonData.data.user.uid || jsonData.data.user._id);",
                  "            ",
                  "            // If admin, save admin token",
                  "            if (jsonData.data.user.role === 'admin' && jsonData.data.token) {",
                  "                pm.collectionVariables.set('adminToken', jsonData.data.token);",
                  "                console.log('✅ Admin token saved');",
                  "            }",
                  "        }",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{userEmail}}\",\n  \"password\": \"{{userPassword}}\",\n  \"displayName\": \"Admin Baixada Vacinada\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/public/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["public", "auth", "register"]
            },
            "description": "Registra um novo usuário simulando o fluxo do frontend"
          }
        },
        {
          "name": "2. Login with Email/Password",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Test response",
                  "pm.test('Login successful', function () {",
                  "    pm.expect(pm.response.code).to.equal(200);",
                  "});",
                  "",
                  "// Extract and save authentication data",
                  "if (pm.response.code === 200) {",
                  "    const jsonData = pm.response.json();",
                  "    ",
                  "    if (jsonData.success && jsonData.data) {",
                  "        // Save custom token for next step",
                  "        if (jsonData.data.customToken) {",
                  "            pm.collectionVariables.set('customToken', jsonData.data.customToken);",
                  "            console.log('✅ Custom token saved:', jsonData.data.customToken.substring(0, 50) + '...');",
                  "        }",
                  "        ",
                  "        if (jsonData.data.uid) {",
                  "            pm.collectionVariables.set('userId', jsonData.data.uid);",
                  "            console.log('✅ User ID saved:', jsonData.data.uid);",
                  "        }",
                  "        ",
                  "        console.log('⚠️ Next step: Use the customToken with signInWithCustomToken to get ID token');",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{userEmail}}\",\n  \"password\": \"{{userPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/public/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["public", "auth", "login"]
            },
            "description": "Login que retorna customToken para ser usado com signInWithCustomToken"
          }
        },
        {
          "name": "3. Firebase signInWithCustomToken (Real)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Verify we have a custom token",
                  "const customToken = pm.collectionVariables.get('customToken');",
                  "if (!customToken) {",
                  "    console.log('❌ No custom token available. Run login first.');",
                  "    throw new Error('Custom token required');",
                  "}",
                  "",
                  "console.log('🔧 Making real Firebase signInWithCustomToken request...');",
                  "console.log('Custom token (first 50 chars):', customToken.substring(0, 50) + '...');"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Test Firebase response",
                  "pm.test('Firebase signInWithCustomToken successful', function () {",
                  "    pm.expect(pm.response.code).to.equal(200);",
                  "});",
                  "",
                  "// Extract ID token from Firebase response",
                  "if (pm.response.code === 200) {",
                  "    const firebaseResponse = pm.response.json();",
                  "    ",
                  "    if (firebaseResponse.idToken) {",
                  "        pm.collectionVariables.set('firebaseToken', firebaseResponse.idToken);",
                  "        console.log('✅ Real Firebase ID Token obtained:', firebaseResponse.idToken.substring(0, 50) + '...');",
                  "        console.log('Token expires in:', firebaseResponse.expiresIn, 'seconds');",
                  "        ",
                  "        // Also set as admin token if this user has admin role",
                  "        pm.collectionVariables.set('adminToken', firebaseResponse.idToken);",
                  "    }",
                  "    ",
                  "    if (firebaseResponse.localId) {",
                  "        pm.collectionVariables.set('userId', firebaseResponse.localId);",
                  "        console.log('✅ Firebase User ID confirmed:', firebaseResponse.localId);",
                  "    }",
                  "} else {",
                  "    console.log('❌ Firebase signInWithCustomToken failed');",
                  "    console.log('Response:', pm.response.text());",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"{{customToken}}\",\n  \"returnSecureToken\": true\n}"
            },
            "url": {
              "raw": "https://identitytoolkit.googleapis.com/v1/accounts:signInWithCustomToken?key={{firebaseApiKey}}",
              "protocol": "https",
              "host": ["identitytoolkit.googleapis.com"],
              "path": ["v1", "accounts:signInWithCustomToken"],
              "query": [
                {
                  "key": "key",
                  "value": "{{firebaseApiKey}}"
                }
              ]
            },
            "description": "Real Firebase signInWithCustomToken - converts customToken to idToken"
          }
        },
        {
          "name": "4. Reactivate User (if needed)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('User reactivation request completed', function () {",
                  "    // Accept both success and not found (user might already be active)",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 404]);",
                  "});",
                  "",
                  "if (pm.response.code === 200) {",
                  "    const jsonData = pm.response.json();",
                  "    if (jsonData.success) {",
                  "        console.log('✅ User reactivated successfully');",
                  "    }",
                  "} else if (pm.response.code === 404) {",
                  "    console.log('ℹ️ User might already be active or not found');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{firebaseToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/admin/users/{{userId}}/reactivate",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "users", "{{userId}}", "reactivate"]
            },
            "description": "Reativa o usuário caso esteja desativado (requer token admin)"
          }
        },
        {
          "name": "5. Verify Token & Get User Profile",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Token verification successful', function () {",
                  "    pm.expect(pm.response.code).to.equal(200);",
                  "});",
                  "",
                  "pm.test('User profile retrieved', function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('success', true);",
                  "    pm.expect(jsonData.data).to.have.property('user');",
                  "});",
                  "",
                  "// Save user info if admin",
                  "if (pm.response.code === 200) {",
                  "    const jsonData = pm.response.json();",
                  "    if (jsonData.success && jsonData.data && jsonData.data.user) {",
                  "        const user = jsonData.data.user;",
                  "        if (user.role === 'admin') {",
                  "            pm.collectionVariables.set('adminToken', pm.collectionVariables.get('firebaseToken'));",
                  "            console.log('✅ Admin privileges confirmed');",
                  "        }",
                  "        console.log('👤 User profile loaded:', user.displayName || user.email);",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{firebaseToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/public/auth/me",
              "host": ["{{baseUrl}}"],
              "path": ["public", "auth", "me"]
            },
            "description": "Verifica o token e obtém o perfil do usuário autenticado"
          }
        }
      ]
    },
