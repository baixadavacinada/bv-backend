              "path": ["admin", "vaccines"]
            }
          }
        },
        {
          "name": "Complete Appointment with Vaccination",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"appliedBy\": \"Dr. João Silva\",\n  \"vaccinationNotes\": \"Vacinação aplicada sem intercorrências\",\n  \"reactions\": \"Sem reações adversas observadas\",\n  \"nextDoseDate\": \"2024-02-15\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/admin/appointments/{{appointmentId}}/complete-vaccination",
              "host": ["{{baseUrl}}"],
              "path": [
                "admin",
                "appointments",
                "{{appointmentId}}",
                "complete-vaccination"
              ]
            }
          }
        },
        {
          "name": "Vaccination Report",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Set date range for report",
                  "const startDate = new Date();",
                  "startDate.setMonth(startDate.getMonth() - 3);",
                  "const endDate = new Date();",
                  "pm.collectionVariables.set('reportStartDate', startDate.toISOString().split('T')[0]);",
                  "pm.collectionVariables.set('reportEndDate', endDate.toISOString().split('T')[0]);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/admin/reports/vaccination?startDate={{reportStartDate}}&endDate={{reportEndDate}}",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "reports", "vaccination"],
              "query": [
                {
                  "key": "startDate",
                  "value": "{{reportStartDate}}"
                },
                {
                  "key": "endDate",
                  "value": "{{reportEndDate}}"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "📖 API Documentation",
      "item": [
        {
          "name": "API Documentation (Scalar)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api-docs",
              "host": ["{{baseUrl}}"],
              "path": ["api-docs"]
            },
            "description": "Abre a documentação interativa da API"
          }
        },
        {
          "name": "OpenAPI Specification JSON",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api-docs.json",
              "host": ["{{baseUrl}}"],
              "path": ["api-docs.json"]
            },
            "description": "Especificação OpenAPI 3.0 em formato JSON"
          }
        }
      ]
    }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Auto-switch between local and production based on environment",
          "const environment = pm.environment.get('environment') || 'production';",
          "if (environment === 'local') {",
          "    pm.collectionVariables.set('baseUrl', pm.collectionVariables.get('localUrl'));",
          "    console.log('🔧 Using LOCAL environment:', pm.collectionVariables.get('localUrl'));",
          "} else {",
          "    pm.collectionVariables.set('baseUrl', 'https://bv-backend-ruby.vercel.app/api');",
          "    console.log('🌐 Using PRODUCTION environment: https://bv-backend-ruby.vercel.app/api');",
          "}",
          "",
          "// Log current request",
          "console.log('📤 Making request to:', pm.request.url.toString());"
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Global test for all requests",
          "pm.test('Response time is acceptable', function () {",
          "    pm.expect(pm.response.responseTime).to.be.below(10000);",
          "});",
          "",
          "pm.test('Response has correct CORS headers', function () {",
          "    pm.expect(pm.response.headers.get('Access-Control-Allow-Origin')).to.exist;",
          "});",
          "",
          "// Log response status",
          "console.log('📥 Response:', pm.response.code, pm.response.status);",
          "",
          "// Log any errors",
          "if (pm.response.code >= 400) {",
          "    console.log('❌ Error response:', pm.response.text());",
          "}"
        ]
      }
    }
  ]
}
