{
 "compilerOptions": {
 "target": "ES2020",
 "module": "commonjs",
 "lib": ["ES2020"],
 "rootDir": "src",
 "outDir": "dist",
 "strict": true,
 "esModuleInterop": true,
 "forceConsistentCasingInFileNames": true,
 "skipLibCheck": true,
 "resolveJsonModule": true,
 "types": ["jest", "node"]
 },
 "baseUrl": "./src",
 "paths": {
 "@/*": ["*"]
 },
 "include": ["src/**/*"],
 "exclude": ["node_modules", "dist"]
}
