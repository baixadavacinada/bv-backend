{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api"
    },
    {
      "source": "/public/(.*)",
      "destination": "/api"
    },
    {
      "source": "/admin/(.*)",
      "destination": "/api"
    },
    {
      "source": "/api-docs",
      "destination": "/api"
    },
    {
      "source": "/",
      "destination": "/api"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  },
  "functions": {
    "api/index.ts": {
      "maxDuration": 30
    }
  },
  "installCommand": "npm install"
}
